{
  "name": "mpp-inspector",
  "version": "0.1.2",
  "description": "Testing and debugging toolkit for Machine Payments Protocol",
  "type": "module",
  "bin": {
    "mpp-inspector": "./dist/bin/mpp-inspector.js"
  },
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:integration:real": "MPP_REAL_ENDPOINT_TESTS=true vitest run --config vitest.integration.config.ts src/__tests__/integration/real-endpoint.test.ts",
    "lint": "tsc --noEmit",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run lint && npm run test && npm run build"
  },
  "keywords": [
    "mpp",
    "machine-payments",
    "http-402",
    "payment-required",
    "payment-protocol",
    "testing",
    "debugging",
    "cli",
    "web3",
    "tempo",
    "blockchain",
    "devtools",
    "api-debugging"
  ],
  "author": "MPP Inspector Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/amgb20/MPP-Inspector.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/amgb20/MPP-Inspector#readme",
  "bugs": {
    "url": "https://github.com/amgb20/MPP-Inspector/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "boxen": "^8.0.1",
    "chalk": "^5.4.1",
    "cli-table3": "^0.6.5",
    "commander": "^13.1.0",
    "mppx": "^0.4.11",
    "ora": "^8.2.0",
    "viem": "^2.23.2"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.4",
    "tsup": "^8.4.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
