{
  "name": "mpp-inspector",
  "description": "Inspect, debug, and test Machine Payments Protocol (HTTP 402) endpoints directly from Claude Code",
  "version": "0.1.0",
  "author": {
    "name": "MPP Inspector Contributors",
    "url": "https://github.com/amgb20/MPP-Inspector"
  },
  "repository": "https://github.com/amgb20/MPP-Inspector",
  "homepage": "https://github.com/amgb20/MPP-Inspector#readme",
  "license": "MIT",
  "keywords": [
    "mpp",
    "http-402",
    "payments",
    "web3",
    "tempo",
    "debugging",
    "mcp"
  ],
  "commands": ["./skills/"],
  "mcpServers": {
    "mpp-inspector": {
      "command": "node",
      "args": ["${CLAUDE_PLUGIN_ROOT}/dist/index.js"]
    }
  },
  "hooks": "./hooks/hooks.json"
}
