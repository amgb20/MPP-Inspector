{
  "name": "@mpp-inspector/plugin",
  "version": "0.1.2",
  "description": "MCP server and Claude Code plugin for Machine Payments Protocol inspection",
  "type": "module",
  "bin": {
    "mpp-inspector-mcp": "./dist/index.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
