  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.25.23",
    "mpp-inspector": "0.1.2"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "tsup": "^8.4.0",
    "typescript": "^6.0.2"
  }
